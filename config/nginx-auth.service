[Unit]
Description=Moonraker Auth Proxy (nginx)
After=network.target nginx-auth-db.service
Requires=nginx-auth-db.service

[Service]
Type=forking
User=root
PIDFile=/run/nginx-auth.pid
ExecStartPre=/usr/sbin/nginx -t -c /etc/moonraker-auth/nginx-auth.conf
ExecStart=/usr/sbin/nginx -c /etc/moonraker-auth/nginx-auth.conf
ExecReload=/bin/kill -s HUP $MAINPID
ExecStop=/bin/kill -s QUIT $MAINPID
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
